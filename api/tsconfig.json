{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["es2023"],

    "paths": {
      "@/*": ["./src/*"]
    },

    "typeRoots": ["./node_modules/@types", "./src/express.d.ts"],

    "module": "node16",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "strict": true,
    "skipLibCheck": true
  }
}
